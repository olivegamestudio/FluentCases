<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <PackageId>FluentCases</PackageId>
        <Version>1.0.0</Version>
        <Authors>Simon Jefferies</Authors>
        <Company>Simon Jefferies</Company>
        <Description>Fluent Given/When/Then helpers for readable .NET tests.</Description>
        <PackageTags>testing;bdd;fluent;given-when-then;xunit</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <RepositoryUrl>https://github.com/olivegamestudio/FluentCases.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageProjectUrl>https://github.com/olivegamestudio/FluentCases</PackageProjectUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <IsPackable>true</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>
